{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "https://chunker.app/schemas/dimension_mappings.schema.json",
  "type": "object",
  "title": "Dimension Mappings",
  "description": "Provides mappings for mapping one dimension to another or removing a dimension.",
  "default": {
    "minecraft:overworld": "minecraft:overworld",
    "minecraft:nether": "minecraft:nether",
    "minecraft:the_end": "minecraft:the_end"
  },
  "examples": [
    {
      "minecraft:overworld": "minecraft:overworld",
      "minecraft:nether": "minecraft:nether",
      "minecraft:the_end": "minecraft:the_end"
    },
    {
      "minecraft:overworld": "minecraft:nether",
      "minecraft:the_end": "minecraft:the_end"
    },
    {
      "minecraft:overworld": "minecraft:overworld"
    }
  ],
  "patternProperties": {
    "^\\$.*": true,
    "^[\\w-]+:[\\w-]+": {
      "type": "string",
      "pattern": "^[\\w-]+:[\\w-]+"
    }
  },
  "additionalProperties": false
}